{
  "roles": {
    "architect": { "provider": "google", "model": "gemini-2.0-pro" },
    "implementer": { "provider": "openai", "model": "gpt-5-codex" },
    "reviewer": { "provider": "anthropic", "model": "claude-opus-4.6" },
    "arbiter": { "provider": "anthropic", "model": "claude-opus-4.6" }
  },
  "providers": {
    "openrouter": { "apiKeyEnv": "OPENROUTER_API_KEY" },
    "anthropic": { "apiKeyEnv": "ANTHROPIC_API_KEY" },
    "google": { "apiKeyEnv": "GOOGLE_API_KEY" },
    "openai": { "apiKeyEnv": "OPENAI_API_KEY" }
  },
  "subscriptionAdapters": [
    {
      "name": "gemini-subscription",
      "command": "node",
      "args": ["scripts/adapters/json-adapter-template.mjs", "--role", "architect"],
      "outputFormat": "json",
      "payloadMode": "stdin",
      "inheritEnv": false,
      "passEnv": ["PATH", "HOME"],
      "testArgs": ["scripts/adapters/json-adapter-template.mjs", "--test"],
      "healthCheckArgs": ["scripts/adapters/health-check.mjs"],
      "env": {
        "ADAPTER_PROVIDER": "gemini"
      },
      "enabled": false
    },
    {
      "name": "codex-subscription",
      "command": "node",
      "args": ["scripts/adapters/json-adapter-template.mjs", "--role", "implementer"],
      "outputFormat": "json",
      "payloadMode": "stdin",
      "inheritEnv": false,
      "passEnv": ["PATH", "HOME"],
      "testArgs": ["scripts/adapters/json-adapter-template.mjs", "--test"],
      "healthCheckArgs": ["scripts/adapters/health-check.mjs"],
      "env": {
        "ADAPTER_PROVIDER": "codex"
      },
      "enabled": false
    },
    {
      "name": "claude-subscription",
      "command": "node",
      "args": ["scripts/adapters/json-adapter-template.mjs", "--role", "reviewer"],
      "outputFormat": "json",
      "payloadMode": "stdin",
      "inheritEnv": false,
      "passEnv": ["PATH", "HOME"],
      "testArgs": ["scripts/adapters/json-adapter-template.mjs", "--test"],
      "healthCheckArgs": ["scripts/adapters/health-check.mjs"],
      "env": {
        "ADAPTER_PROVIDER": "claude"
      },
      "enabled": false
    }
  ],
  "limits": {
    "maxRounds": 3,
    "budgetUsd": 5,
    "timeoutSec": 600
  },
  "execution": {
    "mode": "patch",
    "maxRevisionLoops": 1,
    "requireApplyConfirmation": true,
    "parallelPeerRoles": true,
    "allowFallbackPatch": false
  },
  "team": {
    "mode": "auto",
    "roleStrategy": "strengths_first",
    "debateRounds": 3
  },
  "quality": {
    "requireEvidence": true,
    "rejectUnknownFileRefs": true
  },
  "verification": {
    "profile": "basic",
    "commands": []
  },
  "telemetry": {
    "enabled": false
  }
}
