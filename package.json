{
  "name": "collab-mcp",
  "version": "1.0.0",
  "description": "Multi-model collaborative planning MCP server",
  "type": "module",
  "bin": {
    "collab-mcp": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "node --test --import tsx tests/pipeline.*.test.ts tests/pricing.test.ts tests/providers.base.test.ts tests/subscriptionProvider.test.ts tests/subscriptionCliAdapters.test.ts tests/tools.plan.test.ts tests/tools.compare-review.test.ts tests/mcp.smoke.test.ts",
    "eval:smoke": "npm run smoke:mcp",
    "smoke": "npm run smoke:mcp",
    "smoke:mcp": "npm run build && tsx scripts/mcp-smoke.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "ai",
    "agents",
    "planning",
    "orchestration",
    "mixture-of-agents"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
