{
  "name": "collab-cli",
  "version": "0.1.0",
  "description": "Terminal-native heterogeneous multi-model dev agent",
  "type": "module",
  "bin": {
    "collab": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "node --test --import tsx $(find tests -type f -name '*.test.ts' | sort)",
    "lint": "tsc -p tsconfig.json --noEmit",
    "eval:smoke": "tsx src/index.ts eval run --suite smoke --json",
    "eval:regression": "tsx src/index.ts eval run --suite regression --json"
  },
  "keywords": [
    "cli",
    "ai",
    "agents",
    "orchestration"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
